# Slack 設定 (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Redash 設定
REDASH_URL=https://your-redash-instance.example.com
REDASH_API_KEY=your-redash-api-key

# LLM プロバイダー設定 (anthropic / bedrock / openai)
LLM_PROVIDER=anthropic

# Anthropic API (LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# AWS Bedrock (LLM_PROVIDER=bedrock)
# AWS_DEFAULT_REGION=us-east-1
# AWS_PROFILE=your-profile-name
# 認証は環境変数 / ~/.aws/credentials / SSO / IAM ロールで自動解決

# OpenAI (LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-openai-api-key

# アプリケーション設定
QUERY_CONCURRENCY=5
QUERY_RESULT_MAX_BYTES=10000
LLM_INPUT_MAX_BYTES=50000
INVESTIGATION_TIMEOUT=120s
# LLM_MODEL: Anthropic=claude-haiku-4-5-20251001 / Bedrock=anthropic.claude-3-5-sonnet-20241022-v2:0 / OpenAI=gpt-4o-mini
LLM_MODEL=claude-haiku-4-5-20251001

# グループ設定（allowed_groups に指定した環境変数名でメンバーを管理）
# PAYMENT_TEAM_USERS=UXXXXXXXXX,UYYYYYYYYY
# ANALYTICS_TEAM_USERS=UXXXXXXXXX
