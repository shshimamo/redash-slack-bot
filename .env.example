# Slack 設定 (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Redash 設定
REDASH_URL=https://your-redash-instance.example.com
REDASH_API_KEY=your-redash-api-key

# Anthropic API 設定
ANTHROPIC_API_KEY=sk-ant-your-api-key

# アプリケーション設定
CONFIG_PATH=configs/queries.yaml
QUERY_CONCURRENCY=5
QUERY_RESULT_MAX_BYTES=10000
LLM_INPUT_MAX_BYTES=50000
INVESTIGATION_TIMEOUT=120s
